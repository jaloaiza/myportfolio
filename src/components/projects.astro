---
import ProjectCard from './project-card.astro';
import ProjectDrawer from './project-drawer.astro';
import projectsData from '../data/projects.json';

const { showMoreLink = false, featuredOnly = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const projects = featuredOnly
  ? projectsData.filter((p: any) => p.featured)
  : projectsData;
---

<section id="projects" class="py-4 md:py-20 px-4 md:px-0 overflow-hidden">
  <div class="container mx-auto">
    <div class="mb-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-2 flex items-center gap-4">
          <span class="text-accent">/</span> Featured Projects
        </h2>
      <p class="text-gray font-body text-sm max-w-md">
        These are my featured projects for Production, UI Programming, Gameplay and more! To view all projects, visit the Projects page.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>

    {showMoreLink && (
      <div class="flex justify-center mt-12">
        <a
          href={`${base}projects`}
          class="group relative inline-flex items-center gap-2 px-8 py-3 bg-white/5 border border-white/10 rounded-full text-white font-body text-sm font-medium transition-all duration-300 hover:border-accent/50 hover:bg-accent/10 hover:shadow-[0_0_20px_rgba(164,118,255,0.3)] hover:scale-105"
        >
          More Projects
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
          <div class="absolute inset-0 rounded-full blur-md bg-accent/20 -z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </a>
      </div>
    )}
  </div>
</section>

<ProjectDrawer />

<script>
  const initProjectReveal = () => {
    const cards = document.querySelectorAll('.project-card');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        // Only trigger if the card is 15% visible
        if (entry.isIntersecting) {
          const card = entry.target as HTMLElement;
          const index = Array.from(cards).indexOf(card);
          
          // Stagger effect based on row position
          setTimeout(() => {
            card.classList.add('reveal');
          }, (index % 3) * 150);
          
          observer.unobserve(card);
        }
      });
    }, { 
      threshold: 0.15, // 15%
      rootMargin: '0px 0px -10px 0px' // Negative margin, it must be inside the view
    });

    cards.forEach(card => observer.observe(card));
  };

  // Run only after everything (images, styles) is loaded
  window.addEventListener('load', initProjectReveal);
  
  // Support for Astro View Transitions
  document.addEventListener('astro:after-swap', initProjectReveal);
</script>

<style>
  /* Initial state of the card */
  .project-card {
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Revealed state */
  .project-card.reveal {
    opacity: 1 !important;
    transform: translateY(0) scale(1);
  }
</style>